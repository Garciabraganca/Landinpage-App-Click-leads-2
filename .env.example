# Optional: API Port (defaults to 5501)
PORT=5501

# Optional: downstream destination(s) for profile submissions
# Use one URL:
# BROKER_APPLICATIONS_TARGET_URL=https://seu-backend.com/api/broker-applications
#
# Or many URLs separated by comma. Success requires every configured URL to return 2xx.
# BROKER_APPLICATIONS_DESTINATION_URLS=https://destino-1.com/hook,https://destino-2.com/hook
#
# Optional timeout in milliseconds (defaults to 10000)
# BROKER_APPLICATIONS_TIMEOUT_MS=10000

# Optional escape hatch: allow local acceptance even in production env when no destination is configured
# BROKER_APPLICATIONS_ALLOW_UNCONFIGURED=false

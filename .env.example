# Optional: API Port (defaults to 5501)
PORT=5501

# Optional: downstream destination(s) for profile submissions
# Multiloja: use o endpoint central do CRM e deixe o tenant ser resolvido por store_slug/tenantSlug.
# Use one URL:
# BROKER_APPLICATIONS_TARGET_URL=https://seu-backend.com/api/broker-applications
#
# Or many URLs separated by comma. Success requires every configured URL to return 2xx.
# BROKER_APPLICATIONS_DESTINATION_URLS=https://destino-1.com/hook,https://destino-2.com/hook
# Alternative aliases also accepted:
# SUPERVISOR_DESTINATION_URL=https://seu-backend.com/api/broker-applications
# SUPERVISOR_DESTINATION_URLS=https://destino-1.com/hook,https://destino-2.com/hook
#
# Tenant/profile overrides (priority from most specific to least):
# BROKER_APPLICATIONS_DESTINATION_URLS_<TENANT>_<PROFILE_TYPE>=https://destino-especifico.com/hook
# BROKER_APPLICATIONS_DESTINATION_URLS_<TENANT>=https://destino-do-tenant.com/hook
# BROKER_APPLICATIONS_DESTINATION_URLS_<PROFILE_TYPE>=https://destino-do-profile.com/hook
# Exemplo:
# BROKER_APPLICATIONS_DESTINATION_URLS_DEFAULT_INSTAGRAM=https://seu-backend.com/api/broker-applications/instagram
#
# Optional timeout in milliseconds (defaults to 10000)
# BROKER_APPLICATIONS_TIMEOUT_MS=10000

# Optional escape hatch: allow local acceptance even in production env when no destination is configured
# BROKER_APPLICATIONS_ALLOW_UNCONFIGURED=false
